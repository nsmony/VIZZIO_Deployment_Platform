DATABASE_URL=postgresql://postgres:132005@localhost:5432/vizzio
JWT_SECRET=replace-with-secure-secret
DOWNLOAD_SECRET=replace-with-secure-download-secret
DOWNLOAD_MANAGER_SECRET=replace-with-secure-download-manager-secret
DOWNLOAD_DELIVERY_MODE=nginx
DOWNLOAD_ROOT=/var/www/vizzio/builds
DOWNLOAD_ACCEL_PREFIX=/_vizzio_downloads
